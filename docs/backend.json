
{
  "entities": {
    "RegisteredVisitor": {
      "title": "Registered Visitor",
      "description": "Information about a visitor registered in the library system.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "name": { "type": "string", "description": "Full name of the visitor" },
        "schoolId": { "type": "string", "description": "Format: 00-00000-000" },
        "email": { "type": "string", "format": "email" },
        "collegeDepartment": { "type": "string", "description": "Institutional affiliation (e.g., CICS, COE)" },
        "visitorType": { "type": "string", "enum": ["Student", "Faculty", "Staff", "Guest"] },
        "isBlocked": { "type": "boolean", "description": "Administrative lock status" }
      },
      "required": ["name", "schoolId", "email"]
    },
    "VisitorLog": {
      "title": "Library Entry Log",
      "description": "A secure, immutable record of a library visit.",
      "type": "object",
      "properties": {
        "visitorId": { "type": "string" },
        "schoolId": { "type": "string" },
        "visitorName": { "type": "string" },
        "visitorEmail": { "type": "string" },
        "visitorType": { "type": "string" },
        "college": { "type": "string" },
        "purpose": { "type": "string" },
        "entryDateTime": { "type": "string", "format": "date-time" }
      },
      "required": ["visitorName", "purpose", "entryDateTime"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/registeredVisitors/{visitorId}": {
      "schema": { "$ref": "#/backend/entities/RegisteredVisitor" },
      "description": "The primary registry for known library patrons."
    },
    "/roles_admin/{userId}": {
      "schema": { "type": "object" },
      "description": "Administrative role mapping."
    },
    "/visitorLogs/{logId}": {
      "schema": { "$ref": "#/backend/entities/VisitorLog" },
      "description": "The audit trail for library visitation."
    }
  }
}
