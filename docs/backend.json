{
  "entities": {
    "Visitor": {
      "title": "Visitor",
      "description": "Represents an individual at NEU Library.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "collegeOrOffice": { "type": "string" },
        "visitorType": { "type": "string", "enum": ["Student", "Faculty", "Staff", "Guest"] },
        "isBlocked": { "type": "boolean" },
        "role": { "type": "string", "enum": ["RegularUser", "Admin"] }
      },
      "required": ["id", "name", "email", "collegeOrOffice", "visitorType", "isBlocked", "role"]
    },
    "VisitorLog": {
      "title": "VisitorLog",
      "description": "A log entry for a library visit.",
      "type": "object",
      "properties": {
        "visitorId": { "type": "string" },
        "visitorName": { "type": "string" },
        "visitorEmail": { "type": "string" },
        "visitorType": { "type": "string" },
        "college": { "type": "string" },
        "purpose": { "type": "string" },
        "entryDateTime": { "type": "string", "format": "date-time" }
      },
      "required": ["visitorId", "visitorName", "purpose", "entryDateTime"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/Visitor" },
      "description": "User profile"
    },
    "/roles_admin/{userId}": {
      "schema": { "type": "object" },
      "description": "Admin role marker"
    },
    "/visitorLogs/{logId}": {
      "schema": { "$ref": "#/backend/entities/VisitorLog" },
      "description": "Visit history"
    }
  }
}