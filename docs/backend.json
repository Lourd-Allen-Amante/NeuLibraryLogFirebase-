{
  "entities": {
    "VisitorLog": {
      "title": "VisitorLog",
      "description": "A record of a single library visit entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "visitorId": { "type": "string", "description": "The UID of the visitor (if logged in) or terminal ID." },
        "visitorName": { "type": "string" },
        "schoolId": { "type": "string" },
        "visitorEmail": { "type": "string" },
        "visitorType": { "type": "string", "enum": ["Student", "Faculty", "Staff"] },
        "college": { "type": "string" },
        "purpose": { "type": "string" },
        "entryDateTime": { "type": "string", "format": "date-time" }
      },
      "required": ["visitorName", "schoolId", "purpose", "entryDateTime"]
    },
    "RegisteredVisitor": {
      "title": "RegisteredVisitor",
      "description": "A pre-registered student or faculty member.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "schoolId": { "type": "string" },
        "email": { "type": "string" },
        "collegeDepartment": { "type": "string" },
        "visitorType": { "type": "string" },
        "isBlocked": { "type": "boolean" }
      },
      "required": ["name", "schoolId", "email"]
    },
    "AdminRole": {
      "title": "AdminRole",
      "description": "Designation of administrative privileges for a specific user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "grantedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/visitorLogs/{logId}": {
      "schema": "VisitorLog",
      "description": "Collection of all library entry logs."
    },
    "/registeredVisitors/{visitorId}": {
      "schema": "RegisteredVisitor",
      "description": "Database of authorized students and faculty."
    },
    "/roles_admin/{uid}": {
      "schema": "AdminRole",
      "description": "Registry of authorized library administrators."
    }
  }
}