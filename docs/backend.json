
{
  "entities": {
    "Visitor": {
      "title": "Visitor Profile",
      "description": "Standard user profile for library patrons.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "schoolId": { "type": "string", "description": "Institutional ID number (00-00000-000)" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "collegeOrOffice": { "type": "string", "description": "Institutional affiliation" },
        "visitorType": { "type": "string", "enum": ["Student", "Faculty", "Staff", "Guest"] },
        "isBlocked": { "type": "boolean", "description": "Administrative lock status" },
        "role": { "type": "string", "enum": ["RegularUser", "Admin"] }
      },
      "required": ["id", "name", "email"]
    },
    "VisitorLog": {
      "title": "Library Entry Log",
      "description": "A secure, immutable record of a library visit.",
      "type": "object",
      "properties": {
        "visitorId": { "type": "string" },
        "schoolId": { "type": "string" },
        "visitorName": { "type": "string" },
        "visitorEmail": { "type": "string" },
        "visitorType": { "type": "string", "description": "Student or Employee classification" },
        "college": { "type": "string" },
        "purpose": { "type": "string", "description": "Primary activity selected by user" },
        "entryDateTime": { "type": "string", "format": "date-time" }
      },
      "required": ["visitorId", "visitorName", "purpose", "entryDateTime"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/Visitor" },
      "description": "User profile document containing demographic and status data."
    },
    "/roles_admin/{userId}": {
      "schema": { "type": "object" },
      "description": "Existence of a document here identifies a user with Administrative privileges."
    },
    "/visitorLogs/{logId}": {
      "schema": { "$ref": "#/backend/entities/VisitorLog" },
      "description": "The primary audit trail for library visitation."
    }
  }
}
