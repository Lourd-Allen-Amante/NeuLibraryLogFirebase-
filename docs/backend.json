
{
  "entities": {
    "RegisteredVisitor": {
      "title": "Registered Visitor",
      "description": "Information about a patron registered to use the library.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "schoolId": { "type": "string" },
        "email": { "type": "string" },
        "collegeDepartment": { "type": "string" },
        "visitorType": { "type": "string", "enum": ["Student", "Faculty", "Staff"] },
        "isBlocked": { "type": "boolean" }
      },
      "required": ["name", "schoolId", "email", "visitorType"]
    },
    "VisitorLog": {
      "title": "Visitor Log",
      "description": "A record of a library visit check-in.",
      "type": "object",
      "properties": {
        "visitorId": { "type": "string" },
        "visitorName": { "type": "string" },
        "schoolId": { "type": "string" },
        "visitorEmail": { "type": "string" },
        "visitorType": { "type": "string" },
        "college": { "type": "string" },
        "purpose": { "type": "string" },
        "entryDateTime": { "type": "string", "format": "date-time" }
      },
      "required": ["visitorName", "schoolId", "purpose", "entryDateTime"]
    },
    "AdminRole": {
      "title": "Admin Role",
      "description": "User role assignment for administrators.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["admin"] }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/registeredVisitors/{visitorId}": {
      "schema": "RegisteredVisitor",
      "description": "Collection of all registered patrons."
    },
    "/visitorLogs/{logId}": {
      "schema": "VisitorLog",
      "description": "Logs of library check-ins."
    },
    "/roles_admin/{userId}": {
      "schema": "AdminRole",
      "description": "Firestore-based admin role check."
    }
  }
}
