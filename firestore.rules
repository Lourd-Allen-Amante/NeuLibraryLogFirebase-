
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is a hardcoded superuser
    function isSuperUser(auth) {
      return auth.token.email in ['jcesperanza@neu.edu.ph', 'lourdallen.amante@neu.edu.ph'];
    }

    // Helper to check if user has admin role in Firestore
    function isAdmin(auth) {
      return isSuperUser(auth) || exists(/databases/$(database)/documents/roles_admin/$(auth.uid));
    }

    match /roles_admin/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    match /registeredVisitors/{visitorId} {
      // Terminal needs to search, so allow read for everyone
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth);
    }

    match /visitorLogs/{logId} {
      // Terminal adds logs (even if anonymous)
      allow create: if true;
      allow read, update, delete: if request.auth != null && isAdmin(request.auth);
    }
  }
}
