rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU Library Visitor Log - Security Rules v1.1.0
     * Explicit Admin Authorization for jcesperanza@neu.edu.ph and lourdallen.amante@neu.edu.ph
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'jcesperanza@neu.edu.ph' ||
        request.auth.token.email == 'lourdallen.amante@neu.edu.ph' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    match /registeredVisitors/{visitorId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /visitorLogs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
